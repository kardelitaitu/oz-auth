{
  "productName": "oz-auth",
  "version": "0.1.0",
  "identifier": "com.oz-auth",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "windows": [
      {
        "title": "oz-auth",
        "url": "index.html",
        "width": 420,
        "height": 640,
        "minWidth": 420,
        "minHeight": 640,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [],
    "copyright": "kardelitaitu",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/fingerprint.icns",
      "icons/fingerprint.ico",
      "icons/fingerprint.png"
    ]
  }
}
